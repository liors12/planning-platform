{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Planning Platform",
  "version": "0.1.0",
  "identifier": "co.nessziona.planning-platform",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "פלטפורמת בקרת תכנון — נס ציונה",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:17321 http://localhost:17321; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://127.0.0.1:* http://localhost:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi", "deb", "appimage", "rpm"],
    "resources": ["binaries/sidecar/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 עיריית נס ציונה",
    "category": "Productivity",
    "shortDescription": "פלטפורמת בקרת ציות לתכנון עירוני",
    "longDescription": "כלי לבדיקה אוטומטית של תכניות עיצוב מול תב\"ע וחוברת הנחיות עירוניות.",
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
