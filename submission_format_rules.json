      "category": "submission_format",
      "rule_type": "procedural",
      "deterministic": true,
      "check_method": "pdf_metadata",
      "check_spec": {
        "scope": "all_pages",
        "target_width_pt": 1190,
        "target_height_pt": 841,
        "tolerance_pt": 5,
        "logic": "for each page, abs(width - target_width) <= tolerance AND abs(height - target_height) <= tolerance"
      },
      "verdict_on_pass": "pass",
      "verdict_on_fail": "fail",
      "severity": "major",
      "description_he": "כל עמודי החוברת חייבים להיות בגודל A3 לרוחב (1190×841 נקודות, בסבילות של 5 נקודות).",
      "remediation_he": "ייצוא מחדש של החוברת בפורמט A3 לרוחב."
    },
    {
